# Contact form — use EITHER Resend OR Hostinger SMTP on Vercel (Settings → Environment Variables)

# Option A — Resend (https://resend.com)
# After verifying hagestack.com in Resend, set RESEND_FROM_EMAIL e.g. "HageStack <noreply@hagestack.com>"
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Option B — Hostinger mailbox (no Resend). Password = that mailbox’s password in Hostinger.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@hagestack.com
SMTP_PASSWORD=
# Optional — defaults to "HageStack website <SMTP_USER>"
SMTP_FROM=

# Where inquiries are delivered (defaults to info@hagestack.com)
CONTACT_EMAIL_TO=
