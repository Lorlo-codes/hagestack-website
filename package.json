{
  "name": "hagestack",
  "private": true,
  "version": "0.0.0",
  "description": "Repository root. The Next.js site lives in apps/web — set Vercel Root Directory to apps/web.",
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "start": "npm --prefix apps/web run start",
    "lint": "npm --prefix apps/web run lint",
    "lint:fix": "npm --prefix apps/web run lint:fix",
    "typecheck": "npm --prefix apps/web run typecheck"
  }
}
